# ── Whitelist approach ───────────────────────────────────────────────────────
# Block everything by default. Only explicitly listed items are tracked.
# Nothing internal can ever be accidentally committed.

/*
/.*

# ── Root files ───────────────────────────────────────────────────────────────

!/.gitignore
!/CLAUDE.md
!/LICENSE
!/README.md
!/POWER-USER.md
!/WHATS-NEW.md
!/setup.sh
!/.env.example

# ── Ship the project-level Claude Code settings (incl. SessionStart hooks) ──
# settings.json is the shared config that propagates to every clone.
# settings.local.json stays ignored — per-user overrides never get committed.
!/.claude/
/.claude/*
!/.claude/settings.json

# ── Never commit macOS Finder metadata ───────────────────────────────────────
.DS_Store
**/.DS_Store
# ── Public folders (all contents allowed) ────────────────────────────────────

!/commands/
!/commands/**

# ── Plugin manifest ──────────────────────────────────────────────────────────
!/.claude-plugin/
!/.claude-plugin/**

# ── Tests ────────────────────────────────────────────────────────────────────
!/tests/
!/tests/**

!/workflows/
!/workflows/**

!/integrations/
!/integrations/**

!/guides/
!/guides/**

!/Scripts/
!/Scripts/**
Scripts/__pycache__/

# ── mission-control/ — the Tier 3 surface (tools, setup.sh, Start Bridges) ──
!/mission-control/
!/mission-control/**
mission-control/tools/**/__pycache__/

# ── Re-block macOS Finder metadata after the whitelists ─────────────────────
# Whitelists above (!/integrations/**, !/mission-control/**, etc.) re-include
# every path inside those folders — including .DS_Store. Re-block it here.
**/.DS_Store
.DS_Store

# ── docs/ — explicitly list allowed files, block everything else ─────────────

!/docs/
docs/*
docs/.*
!docs/GOLDEN_RULES.md
!docs/INTENT_MAPPING.md
!docs/MCP_SETUP.md
!docs/TOOL_REFERENCE.md
!docs/WORKFLOWS.md
!docs/SLASH_COMMANDS.md
!docs/CLAUDE_DESKTOP_PROMPTS.md
!docs/welcome.html
!docs/install.html
