# ── Whitelist approach ───────────────────────────────────────────────────────
# Block everything by default. Only explicitly listed items are tracked.
# Nothing internal can ever be accidentally committed.

/*
/.*

# ── Root files ───────────────────────────────────────────────────────────────

!/.gitignore
!/CLAUDE.md
!/LICENSE
!/README.md
!/WHATS-NEW.md
!/setup.sh
!/.env.example
!/Start*Bridges.*

# ── Never commit macOS Finder metadata ───────────────────────────────────────
.DS_Store
**/.DS_Store
# ── Public folders (all contents allowed) ────────────────────────────────────

!/commands/
!/commands/**

!/workflows/
!/workflows/**

!/integrations/
!/integrations/**

!/guides/
!/guides/**

!/Scripts/
!/Scripts/**
Scripts/__pycache__/

!/tools/
!/tools/**
tools/**/__pycache__/

# ── docs/ — explicitly list allowed files, block everything else ─────────────

!/docs/
docs/*
docs/.*
!docs/GOLDEN_RULES.md
!docs/INTENT_MAPPING.md
!docs/MCP_SETUP.md
!docs/TOOL_REFERENCE.md
!docs/WORKFLOWS.md
!docs/MCP-DAY-AGENDA.md
!docs/CLAUDE_DESKTOP_PROMPTS.md
!docs/welcome.html
!docs/install.html
